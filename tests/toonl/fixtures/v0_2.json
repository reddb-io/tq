{
  "version": "toonl-v0.2",
  "extension": ".toonl",
  "mediaHint": "application/toonl",
  "tests": [
    {
      "name": "decode/continuation-header-is-transparent",
      "kind": "decode",
      "input": "[]{id,name}:\n1,Ada\n[~]{id,name}:\n2,Linus\n[=2]\n",
      "segments": [
        {
          "delimiter": ",",
          "fields": ["id", "name"],
          "rows": [
            ["1", "Ada"],
            ["2", "Linus"]
          ]
        }
      ]
    },
    {
      "name": "decode/pipe-continuation-header-is-transparent",
      "kind": "decode",
      "input": "[|]{id|name}:\n1|Ada\n[~|]{id|name}:\n2|Linus\n[=2]\n",
      "segments": [
        {
          "delimiter": "|",
          "fields": ["id", "name"],
          "rows": [
            ["1", "Ada"],
            ["2", "Linus"]
          ]
        }
      ]
    },
    {
      "name": "close-transform/discards-continuation-header",
      "kind": "close-transform",
      "input": "[]{id,name}:\n1,Ada\n[~]{id,name}:\n2,Linus\n[=2]\n",
      "expectedToonDocuments": [
        "[2]{id,name}:\n  1,Ada\n  2,Linus\n"
      ]
    },
    {
      "name": "encode/continuation-every-two-rows",
      "kind": "encode",
      "delimiter": ",",
      "fields": ["id", "name"],
      "continuationEveryRows": 2,
      "rows": [
        ["1", "Ada"],
        ["2", "Linus"],
        ["3", "Grace"]
      ],
      "expected": "[]{id,name}:\n1,Ada\n2,Linus\n[~]{id,name}:\n3,Grace\n[=3]\n"
    },
    {
      "name": "encode/tagged-row-interleaved-lanes",
      "kind": "encode-tagged-records",
      "operations": [
        { "tag": "req", "record": { "method": "GET", "path": "/health", "status": 200 } },
        { "tag": "metric", "record": { "name": "cpu", "value": 0.42 } },
        { "tag": "req", "record": { "status": 401, "path": "/login", "method": "POST" } },
        { "tag": "metric", "record": { "value": 0.55, "name": "cpu" } },
        { "tag": "req", "record": { "method": "POST", "path": "/login", "status": 200, "duration_ms": 32 } }
      ],
      "expected": "[]<req>{method,path,status}:\nreq:GET,/health,200\n[]<metric>{name,value}:\nmetric:cpu,0.42\nreq:POST,/login,401\nmetric:cpu,0.55\n[]<req>{method,path,status,duration_ms}:\nreq:POST,/login,200,32\n"
    },
    {
      "name": "error/continuation-before-header",
      "kind": "error",
      "input": "[~]{id,name}:\n1,Ada\n",
      "expectedError": "continuation header before header"
    },
    {
      "name": "error/continuation-header-field-mismatch",
      "kind": "error",
      "input": "[]{id,name}:\n1,Ada\n[~]{id,role}:\n2,dev\n",
      "expectedError": "continuation header mismatch"
    },
    {
      "name": "error/continuation-header-delimiter-mismatch",
      "kind": "error",
      "input": "[]{id,name}:\n1,Ada\n[~|]{id|name}:\n2|Linus\n",
      "expectedError": "continuation header mismatch"
    },
    {
      "name": "v0.1-reject/continuation-header",
      "kind": "v0.1-error",
      "input": "[]{id,name}:\n1,Ada\n[~]{id,name}:\n2,Linus\n",
      "expectedError": "invalid header delimiter"
    },
    {
      "name": "decode/tagged-row-interleave-to-per-lane-segments",
      "kind": "decode",
      "input": "[]<req>{method,path,status}:\n[]<metric>{name,value}:\nreq:GET,/health,200\nmetric:cpu,0.42\nreq:POST,/login,401\nmetric:cpu,0.55\n",
      "segments": [
        {
          "delimiter": ",",
          "fields": ["method", "path", "status"],
          "rows": [
            ["GET", "/health", "200"],
            ["POST", "/login", "401"]
          ]
        },
        {
          "delimiter": ",",
          "fields": ["name", "value"],
          "rows": [
            ["cpu", "0.42"],
            ["cpu", "0.55"]
          ]
        }
      ]
    },
    {
      "name": "decode/tagged-row-coexists-with-anonymous-lane",
      "kind": "decode",
      "input": "[]{event}:\n[]<audit>{actor,action}:\nstarted\naudit:alice,login\nfinished\n",
      "segments": [
        {
          "delimiter": ",",
          "fields": ["event"],
          "rows": [
            ["started"],
            ["finished"]
          ]
        },
        {
          "delimiter": ",",
          "fields": ["actor", "action"],
          "rows": [
            ["alice", "login"]
          ]
        }
      ]
    },
    {
      "name": "decode/tagged-row-redefinition-rotates-lane",
      "kind": "decode",
      "input": "[]<req>{method,path}:\nreq:GET,/health\n[]<req>{method,path,status}:\nreq:POST,/login,401\n",
      "segments": [
        {
          "delimiter": ",",
          "fields": ["method", "path"],
          "rows": [
            ["GET", "/health"]
          ]
        },
        {
          "delimiter": ",",
          "fields": ["method", "path", "status"],
          "rows": [
            ["POST", "/login", "401"]
          ]
        }
      ]
    },
    {
      "name": "close-transform/tagged-row-per-lane-documents",
      "kind": "close-transform",
      "input": "[]<req>{method,path,status}:\n[]<metric>{name,value}:\nreq:GET,/health,200\nmetric:cpu,0.42\nreq:POST,/login,401\nmetric:cpu,0.55\n",
      "expectedToonDocuments": [
        "[2]{method,path,status}:\n  GET,/health,200\n  POST,/login,401\n",
        "[2]{name,value}:\n  cpu,0.42\n  cpu,0.55\n"
      ],
      "expectedInterleavedToonDocuments": [
        "[1]{method,path,status}:\n  GET,/health,200\n",
        "[1]{name,value}:\n  cpu,0.42\n",
        "[1]{method,path,status}:\n  POST,/login,401\n",
        "[1]{name,value}:\n  cpu,0.55\n"
      ]
    },
    {
      "name": "error/tagged-row-live-lane-overflow",
      "kind": "error",
      "input": "[]<a>{v}:\n[]<b>{v}:\n[]<c>{v}:\n[]<d>{v}:\n[]<e>{v}:\n[]<f>{v}:\n[]<g>{v}:\n[]<h>{v}:\n[]<i>{v}:\n",
      "expectedError": "too many tagged lanes"
    },
    {
      "name": "error/tagged-row-unknown-tag",
      "kind": "error",
      "input": "[]<req>{method,path}:\nmetric:cpu,0.42\n",
      "expectedError": "unknown tag"
    },
    {
      "name": "error/tagged-row-invalid-tag-declaration",
      "kind": "error",
      "input": "[]<bad:tag>{v}:\n",
      "expectedError": "invalid tag"
    },
    {
      "name": "error/tagged-row-invalid-tag-prefix",
      "kind": "error",
      "input": "[]<req>{v}:\nreq~x:1\n",
      "expectedError": "invalid tag"
    },
    {
      "name": "v0.1-reject/tagged-schema-declaration",
      "kind": "v0.1-error",
      "input": "[]<req>{method,path}:\nreq:GET,/health\n",
      "expectedError": "invalid header"
    },
    {
      "name": "v0.1-reject/tagged-row",
      "kind": "v0.1-error",
      "input": "[]{method,path}:\nreq:GET,/health\n",
      "expectedError": "row arity mismatch"
    }
  ]
}
