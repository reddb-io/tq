{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "TOONL",
  "scopeName": "source.toonl",
  "patterns": [
    { "include": "#schema-declaration" },
    { "include": "#continuation-header" },
    { "include": "#segment-header" },
    { "include": "#trailer" },
    { "include": "#reserved-line" },
    { "include": "#tagged-row" },
    { "include": "#string" },
    { "include": "#constant" },
    { "include": "#number" },
    { "include": "#delimiter" },
    { "include": "#unquoted-cell" }
  ],
  "repository": {
    "schema-declaration": {
      "comment": "TOONL v0.2 (R3) named schema declaration: `[]<tag>{field1,field2}:`.",
      "match": "^(\\[)(\\])(<)([A-Za-z0-9_-]+)(>)(\\{.*\\})(:)[ \\t]*$",
      "captures": {
        "1": { "name": "punctuation.section.brackets.begin.toonl" },
        "2": { "name": "punctuation.section.brackets.end.toonl" },
        "3": { "name": "punctuation.definition.tag.begin.toonl" },
        "4": { "name": "entity.name.type.schema.toonl" },
        "5": { "name": "punctuation.definition.tag.end.toonl" },
        "6": { "patterns": [{ "include": "#field-list" }] },
        "7": { "name": "punctuation.separator.key-value.toonl" }
      }
    },
    "continuation-header": {
      "comment": "TOONL v0.2 (R1) continuation header: `[~]{field1,field2}:`. The `~` sentinel is deliberately not a delimiter symbol, so v0.1 decoders reject it.",
      "match": "^(\\[)(~)(\\])(\\{.*\\})(:)[ \\t]*$",
      "captures": {
        "1": { "name": "punctuation.section.brackets.begin.toonl" },
        "2": { "name": "keyword.control.continuation.toonl" },
        "3": { "name": "punctuation.section.brackets.end.toonl" },
        "4": { "patterns": [{ "include": "#field-list" }] },
        "5": { "name": "punctuation.separator.key-value.toonl" }
      }
    },
    "segment-header": {
      "comment": "Open segment header `[]{fields}:` with optional delimiter symbol (`[|]`, `[<TAB>]`). Digits are tolerated (`[N]{...}:`) so close-transformed material carrying a .toonl extension still highlights.",
      "match": "^(\\[)([0-9]+)?([|\\t])?(\\])(\\{.*\\})(:)[ \\t]*$",
      "captures": {
        "1": { "name": "punctuation.section.brackets.begin.toonl" },
        "2": { "name": "constant.numeric.row-count.toonl" },
        "3": { "name": "keyword.operator.delimiter.toonl" },
        "4": { "name": "punctuation.section.brackets.end.toonl" },
        "5": { "patterns": [{ "include": "#field-list" }] },
        "6": { "name": "punctuation.separator.key-value.toonl" }
      }
    },
    "trailer": {
      "comment": "Segment trailer `[=N]` — verifies the row count of the segment it closes.",
      "name": "meta.trailer.toonl",
      "match": "^(\\[=)([0-9]+)(\\])[ \\t]*$",
      "captures": {
        "1": { "name": "keyword.control.trailer.toonl" },
        "2": { "name": "constant.numeric.row-count.toonl" },
        "3": { "name": "keyword.control.trailer.toonl" }
      }
    },
    "reserved-line": {
      "comment": "Lines starting with `- ` are reserved for a future nested-frame syntax; decoders MUST reject them.",
      "match": "^- .*$",
      "name": "invalid.illegal.reserved-prefix.toonl"
    },
    "tagged-row": {
      "comment": "TOONL v0.2 (R3) tagged row: `tag:cell1,cell2`. The cells after the tag are tokenized by the shared cell patterns.",
      "match": "^([A-Za-z0-9_-]+)(:)",
      "captures": {
        "1": { "name": "entity.name.tag.row-tag.toonl" },
        "2": { "name": "punctuation.separator.tag.toonl" }
      }
    },
    "field-list": {
      "patterns": [
        { "match": "[{}]", "name": "punctuation.section.braces.toonl" },
        { "include": "#string" },
        { "match": "[A-Za-z_][A-Za-z0-9_.]*", "name": "variable.parameter.field.toonl" },
        { "match": "[,|\\t]", "name": "punctuation.separator.fields.toonl" }
      ]
    },
    "string": {
      "comment": "Cells follow TOON quoting: double quotes with the closed v3.3 escape repertoire.",
      "name": "string.quoted.double.toonl",
      "begin": "\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.toonl" } },
      "end": "\"|$",
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.toonl" } },
      "patterns": [
        { "name": "constant.character.escape.toonl", "match": "\\\\(?:[\\\\\"nrt]|u[0-9A-Fa-f]{4})" },
        { "name": "invalid.illegal.escape.toonl", "match": "\\\\." }
      ]
    },
    "constant": {
      "match": "(?<![\\w.\"-])(true|false|null)(?![\\w.-])",
      "name": "constant.language.toonl"
    },
    "number": {
      "comment": "Canonical decimal plus accepted exponent forms; leading-zero tokens decode as strings and stay unhighlighted.",
      "match": "(?<![\\w.\"-])-?(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?(?:[eE][+-]?[0-9]+)?(?![\\w.-])",
      "name": "constant.numeric.toonl"
    },
    "delimiter": {
      "match": "[,|\\t]",
      "name": "punctuation.separator.sequence.toonl"
    },
    "unquoted-cell": {
      "comment": "Fallback: an unquoted string cell. Runs last, so headers, tags, constants and numbers win at the same position.",
      "match": "[^,|\\t\\s\"][^,|\\t]*",
      "name": "string.unquoted.toonl"
    }
  }
}
