{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "TOON/TOONL Markdown fences",
  "scopeName": "markdown.toon.codeblock",
  "injectionSelector": "L:text.html.markdown",
  "patterns": [
    { "include": "#fenced-code-block-toonl" },
    { "include": "#fenced-code-block-toon" }
  ],
  "repository": {
    "fenced-code-block-toonl": {
      "name": "markup.fenced_code.block.markdown",
      "begin": "(^|\\G)(\\s*)(`{3,}|~{3,})\\s*(?i:(toonl)((\\s+|:|,|\\{|\\?)[^`]*)?$)",
      "end": "(^|\\G)(\\2|\\s{0,3})(\\3)\\s*$",
      "beginCaptures": {
        "3": { "name": "punctuation.definition.markdown" },
        "4": { "name": "fenced_code.block.language.markdown" },
        "5": { "name": "fenced_code.block.language.attributes.markdown" }
      },
      "endCaptures": {
        "3": { "name": "punctuation.definition.markdown" }
      },
      "patterns": [
        {
          "begin": "(^|\\G)(\\s*)(.*)",
          "while": "(^|\\G)(?!\\s*([`~]{3,})\\s*$)",
          "contentName": "meta.embedded.block.toonl",
          "patterns": [{ "include": "source.toonl" }]
        }
      ]
    },
    "fenced-code-block-toon": {
      "name": "markup.fenced_code.block.markdown",
      "begin": "(^|\\G)(\\s*)(`{3,}|~{3,})\\s*(?i:(toon)((\\s+|:|,|\\{|\\?)[^`]*)?$)",
      "end": "(^|\\G)(\\2|\\s{0,3})(\\3)\\s*$",
      "beginCaptures": {
        "3": { "name": "punctuation.definition.markdown" },
        "4": { "name": "fenced_code.block.language.markdown" },
        "5": { "name": "fenced_code.block.language.attributes.markdown" }
      },
      "endCaptures": {
        "3": { "name": "punctuation.definition.markdown" }
      },
      "patterns": [
        {
          "begin": "(^|\\G)(\\s*)(.*)",
          "while": "(^|\\G)(?!\\s*([`~]{3,})\\s*$)",
          "contentName": "meta.embedded.block.toon",
          "patterns": [{ "include": "source.toon" }]
        }
      ]
    }
  }
}
